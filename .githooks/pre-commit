#!/usr/bin/env bash
set -euo pipefail

if [[ "${SKIP_ENV_CHECK:-0}" == "1" ]]; then
  echo "pre-commit: SKIP_ENV_CHECK=1 -> skipping env check"
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if [[ ! -f ".env" ]]; then
  echo "pre-commit: .env not found. Create it from .env.example first." >&2
  exit 1
fi

if [[ ! -x "scripts/check_env.sh" ]]; then
  chmod +x "scripts/check_env.sh" || true
fi

scripts/check_env.sh ".env" ".env.example" ".env.required"
