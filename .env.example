BIZNISWEB_API_TOKEN=your_api_token_here
BIZNISWEB_API_URL=https://vevo.flox.sk/api/graphql

# Web login credentials for invoice generation (optional)
BIZNISWEB_USERNAME=your_username_here
BIZNISWEB_PASSWORD=your_password_here

# Facebook Marketing API credentials (optional)
# To get these credentials:
# 1. Go to https://developers.facebook.com/
# 2. Create an app or use existing one
# 3. Get your App ID and App Secret from Settings > Basic
# 4. Generate a User Access Token with ads_read permission
# 5. Find your Ad Account ID in Facebook Ads Manager (format: act_XXXXXXXXX)
FACEBOOK_APP_ID=your_app_id_here
FACEBOOK_APP_SECRET=your_app_secret_here
FACEBOOK_ACCESS_TOKEN=your_access_token_here
FACEBOOK_AD_ACCOUNT_ID=act_your_ad_account_id_here

# Google Ads API credentials (optional)
# To get these credentials:
# 1. Get developer token: https://ads.google.com/aw/apicenter
# 2. Create OAuth2 credentials in Google Cloud Console
# 3. Run: python google_ads.py --setup to generate refresh token
# 4. Customer ID is your Google Ads account ID without dashes
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_ADS_CLIENT_ID=your_client_id_here
GOOGLE_ADS_CLIENT_SECRET=your_client_secret_here
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here
GOOGLE_ADS_CUSTOMER_ID=7592903323
# Optional: For MCC (Manager) accounts only
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Daily report automation (AWS SES + optional S3 links)
# Report period defaults: from REPORT_FROM_DATE to "yesterday" in REPORT_TIMEZONE
REPORT_FROM_DATE=2025-05-03
REPORT_TO_DATE=
REPORT_TIMEZONE=Europe/Bratislava
# Optional cache controls for automated runs (default false)
REPORT_FORCE_CLEAR_CACHE=false
REPORT_FORCE_NO_CACHE=false

# Optional shared HTTP hardening defaults for external integrations
REPORT_HTTP_CONNECT_TIMEOUT_SEC=10
REPORT_HTTP_READ_TIMEOUT_SEC=30
REPORT_HTTP_RETRY_TOTAL=3
REPORT_HTTP_RETRY_BACKOFF_SEC=0.5

# Optional integration-specific overrides
BIZNISWEB_API_TIMEOUT_SEC=30
BIZNISWEB_WEB_TIMEOUT_SEC=30
FACEBOOK_API_TIMEOUT_SEC=30
WEATHER_API_TIMEOUT_SEC=30

# AWS region used by SES/S3 clients
AWS_REGION=eu-central-1

# SES email settings
REPORT_EMAIL_FROM=reports@example.com
REPORT_EMAIL_TO=owner@example.com
REPORT_EMAIL_SUBJECT=Daily report Vevo

# Optional: upload generated files to S3 and include presigned links in email
REPORT_S3_BUCKET=
REPORT_S3_PREFIX=daily-reports
# Default 7 days
REPORT_S3_PRESIGN_EXPIRES_SEC=604800
